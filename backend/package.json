{
  "name": "tweb-messenger-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node scripts/ensure-prisma-client.js && node src/server.js",
    "prisma:ensure": "node scripts/ensure-prisma-client.js",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:push": "prisma db push --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^2.4.3",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "prisma": "^6.7.0"
  }
}
